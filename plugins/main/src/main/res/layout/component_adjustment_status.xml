<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/dashboard_card_surface"
        android:orientation="vertical"
        android:paddingStart="@dimen/dashboard_card_inner_padding_horizontal"
        android:paddingEnd="@dimen/dashboard_card_inner_padding_horizontal"
        android:paddingTop="@dimen/dashboard_card_inner_padding_vertical"
        android:paddingBottom="@dimen/dashboard_card_inner_padding_vertical">

        <TextView
            android:id="@+id/adjustment_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dashboard_adjustments"
            android:textAppearance="@style/TextAppearance.AAPS.Dashboard.SectionTitle" />

        <TextView
            android:id="@+id/glycemia_line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dashboard_section_spacing"
            android:textAppearance="@style/TextAppearance.AAPS.Dashboard.PrimaryLine" />

        <TextView
            android:id="@+id/prediction_line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dashboard_row_spacing_small"
            android:textAppearance="@style/TextAppearance.AAPS.Dashboard.SecondaryLine" />

        <TextView
            android:id="@+id/iob_activity_line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dashboard_row_spacing_medium"
            android:textAppearance="@style/TextAppearance.AAPS.Dashboard.SecondaryLine" />

        <TextView
            android:id="@+id/decision_line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dashboard_row_spacing_small"
            android:textAppearance="@style/TextAppearance.AAPS.Dashboard.SecondaryLine" />

        <TextView
            android:id="@+id/mode_line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dashboard_row_spacing_medium"
            android:textAppearance="@style/TextAppearance.AAPS.Dashboard.SecondaryLine"
            android:visibility="gone" />

        <HorizontalScrollView
            android:id="@+id/pump_badges_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dashboard_row_spacing_medium"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/pump_badge_reservoir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dashboard_chip_spacing"
                    android:background="@drawable/dashboard_chip_background"
                    android:paddingHorizontal="@dimen/dashboard_chip_padding_horizontal"
                    android:paddingVertical="@dimen/dashboard_chip_padding_vertical"
                    android:textAppearance="@style/TextAppearance.AAPS.Dashboard.SecondaryLine"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    tools:text="Res. 120 U" />

                <TextView
                    android:id="@+id/pump_badge_site"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dashboard_chip_spacing"
                    android:background="@drawable/dashboard_chip_background"
                    android:paddingHorizontal="@dimen/dashboard_chip_padding_horizontal"
                    android:paddingVertical="@dimen/dashboard_chip_padding_vertical"
                    android:textAppearance="@style/TextAppearance.AAPS.Dashboard.SecondaryLine"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    tools:text="Site 3d 4h" />

                <TextView
                    android:id="@+id/pump_badge_sensor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/dashboard_chip_background"
                    android:paddingHorizontal="@dimen/dashboard_chip_padding_horizontal"
                    android:paddingVertical="@dimen/dashboard_chip_padding_vertical"
                    android:textAppearance="@style/TextAppearance.AAPS.Dashboard.SecondaryLine"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    tools:text="Sens. 6d 2h" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/safety_line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dashboard_row_spacing_small"
            android:textAppearance="@style/TextAppearance.AAPS.Dashboard.SecondaryLine" />

        <TextView
            android:id="@+id/empty_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dashboard_section_spacing"
            android:text="@string/dashboard_no_adjustments"
            android:textAppearance="@style/TextAppearance.AAPS.Dashboard.PrimaryLine" />

        <LinearLayout
            android:id="@+id/adjustment_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dashboard_section_spacing"
            android:orientation="vertical" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/run_loop_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dashboard_section_spacing"
            android:text="@string/dashboard_run_loop"
            style="@style/Widget.AAPS.Dashboard.RunLoopButton" />

    </LinearLayout>
</merge>
